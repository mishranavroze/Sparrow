# === Global Settings ===
GEMINI_API_KEY=
CHROME_USER_DATA_DIR=~/.noctua-chrome-profile
BASE_URL=https://your-replit-app.replit.app
GENERATION_HOUR=2
GENERATION_MINUTE=30
CRON_SECRET=

# Google Cloud Storage (optional — for permanent episode MP3 hosting)
GCS_BUCKET_NAME=
GCS_CREDENTIALS_JSON=

# === Show Configuration ===
# Show metadata (title, description, segments, icon, weather) is defined
# in shows.json. Only secrets go here as SHOW_{ID}_* env vars.
#
# SHOW_IDS is optional — when empty, ALL shows in shows.json are activated.
# Set it to filter which shows to run, e.g. SHOW_IDS=sparrow
#
# Multiple shows can share a single Gmail account (use the same credentials
# for both) or use separate accounts. Set SHOW_{ID}_GMAIL_LABEL to filter
# which labeled emails feed each show.

# --- Example show: sparrow ---
SHOW_SPARROW_GMAIL_CREDENTIALS_JSON='{...}'
SHOW_SPARROW_GMAIL_TOKEN_JSON='{...}'
SHOW_SPARROW_GMAIL_LABEL=Newsletters
SHOW_SPARROW_NOTEBOOKLM_NOTEBOOK_URL=https://notebooklm.google.com/notebook/xxxxx
SHOW_SPARROW_GOOGLE_ACCOUNT_EMAIL=your.email@gmail.com
SHOW_SPARROW_GOOGLE_ACCOUNT_PASSWORD=

# --- To add another show, define it in shows.json and add secrets here ---
# SHOW_NIGHTHAWK_GMAIL_CREDENTIALS_JSON='{...}'
# SHOW_NIGHTHAWK_GMAIL_TOKEN_JSON='{...}'
# SHOW_NIGHTHAWK_GMAIL_LABEL=Newsletters
# SHOW_NIGHTHAWK_NOTEBOOKLM_NOTEBOOK_URL=https://notebooklm.google.com/notebook/yyyyy
# SHOW_NIGHTHAWK_GOOGLE_ACCOUNT_EMAIL=another.email@gmail.com
# SHOW_NIGHTHAWK_GOOGLE_ACCOUNT_PASSWORD=
